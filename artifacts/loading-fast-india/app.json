{
  "expo": {
    "name": "Loading Fast India",
    "slug": "loading-fast-india",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "loading-fast-india",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A2540"
    },
    "updates": {
      "fallbackToCacheTimeout": 10000,
      "checkAutomatically": "ON_LOAD",
      "enabled": true,
      "url": "https://u.expo.dev/90d24ee7-082f-4a98-b2f2-e57f8c87c9d5"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.loadingfastindia.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Loading Fast India को GPS चाहिए ताकि ड्राइवर की location दिखाई दे",
        "NSLocationAlwaysUsageDescription": "Loading Fast India को GPS चाहिए ताकि ट्रिप tracking हो सके",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Loading Fast India को GPS चाहिए ताकि नज़दीकी ट्रिप की notification मिले।",
        "NSCameraUsageDescription": "Loading Fast India को Camera चाहिए ताकि Aadhaar, License, RC Book और Selfie की photo ली जा सके।",
        "NSPhotoLibraryUsageDescription": "Loading Fast India को Gallery access चाहिए ताकि document photo upload हो सके।"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A2540"
      },
      "package": "com.loadingfastindia.app",
      "versionCode": 5,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "loadingfastindia.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Loading Fast India को Gallery access चाहिए ताकि document photo upload हो सके।",
          "cameraPermission": "Loading Fast India को Camera चाहिए ताकि KYC documents की photo ली जा सके।",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Loading Fast India को GPS की जरूरत है ताकि नज़दीकी ट्रिप की notification मिले।"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0A2540",
          "androidMode": "default",
          "androidCollapsedTitle": "Loading Fast India"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "90d24ee7-082f-4a98-b2f2-e57f8c87c9d5"
      }
    }
  }
}
